{
  "manifest_version": 3,
  "name": "Mistake Notebook — UWorld Capture",
  "version": "1.0.0",
  "description": "Capture UWorld questions you got wrong and send them to your Mistake Notebook",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.uworld.com/*",
        "*://apps.uworld.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
