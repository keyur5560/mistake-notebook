{
  "manifest_version": 3,
  "name": "Mistake Notebook — UWorld Capture",
  "version": "1.1.0",
  "description": "Capture UWorld questions you got wrong and send them to your Mistake Notebook",
  "permissions": ["storage"],
  "host_permissions": [
    "<all_urls>",
    "https://api.groq.com/*",
    "https://*.supabase.co/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.uworld.com/*",
        "*://apps.uworld.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
